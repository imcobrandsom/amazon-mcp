{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/bol-sync-start",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/bol-sync-complete",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/bol-sync-extended",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/bol-sync-competitor-analysis",
      "schedule": "30 */6 * * *"
    },
    {
      "path": "/api/bol-sync-keywords",
      "schedule": "0 7 * * 1"
    }
  ],
  "functions": {
    "api/bol-sync-start.ts": {
      "maxDuration": 300
    },
    "api/bol-sync-trigger.ts": {
      "maxDuration": 300
    },
    "api/bol-sync-extended.ts": {
      "maxDuration": 300
    },
    "api/bol-sync-competitor-analysis.ts": {
      "maxDuration": 300
    },
    "api/bol-content-upload.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/bol-content-*.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/test-content-tables.ts": {
      "maxDuration": 10,
      "memory": 512
    }
  }
}
